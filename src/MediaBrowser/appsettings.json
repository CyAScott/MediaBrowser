{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "db": {
    "connectionString": "Data Source=file::memory:?cache=shared",
    "migrateOnBoot": true
  },
  "jwt": {
    "audience": "mediaBrowserAudience",
    "expiryMinutes": "60",
    "issuer": "mediaBrowserIssuer",
    "secretKey": "mediaBrowserSecretKey"
  },
  "media": {
    "castDirectory": "/cast",
    "directorsDirectory": "/directors",
    "genresDirectory": "/genres",
    "mediaDirectory": "/media",
    "producersDirectory": "/producers",
    "writersDirectory": "/writers"
  }
}
