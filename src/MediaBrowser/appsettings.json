{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "cookies": {
    "secure": true
  },
  "db": {
    "migrateOnBoot": true,
    "mySqlConnectionString": "",
    "postgresConnectionString": "",
    "sqliteConnectionString": "Data Source=file::memory:?cache=shared",
    "sqlServerConnectionString": "",
    "type": "sqlite"
  },
  "jwt": {
    "audience": "mediaBrowserAudience",
    "expiryMinutes": 60,
    "issuer": "mediaBrowserIssuer",
    "secretKey": "mediaBrowserSecretKey"
  },
  "initial": {
    "username": "admin",
    "password": "admin"
  },
  "media": {
    "castDirectory": "/cast",
    "directorsDirectory": "/directors",
    "genresDirectory": "/genres",
    "importDirectory": null,
    "importExtensions": {
      "aac": {"order": 7, "mime": "audio/aac", "ext": "aac"},
      "adts": {"order": 7, "mime": "audio/aac", "ext": "aac"},
      "aif": {"order": 10, "mime": "audio/aiff", "ext": "aif"},
      "aifc": {"order": 10, "mime": "audio/aiff", "ext": "aif"},
      "aiff": {"order": 10, "mime": "audio/aiff", "ext": "aif"},
      "bmp": {"order": 17, "mime": "image/bmp", "ext": "bmp"},
      "cdda": {"order": 10, "mime": "audio/aiff", "ext": "aif"},
      "f4v": {"order": 1, "mime": "video/mp4", "ext": "mp4"},
      "flac": {"order": 6, "mime": "audio/flac", "ext": "flac"},
      "gif": {"order": 16, "mime": "image/gif", "ext": "gif"},
      "jpg": {"order": 13, "mime": "image/jpeg", "ext": "jpg"},
      "jpge": {"order": 14, "mime": "image/jpeg", "ext": "jpg"},
      "m1v": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
      "m2v": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
      "mod": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
      "mov": {"order": 12, "mime": "video/quicktime", "ext": "mov"},
      "mp2": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
      "mp2v": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
      "mp3": {"order": 8, "mime": "audio/mpeg", "ext": "mp3"},
      "mp4": {"order": 1, "mime": "video/mp4", "ext": "mp4"},
      "mp4v": {"order": 1, "mime": "video/mp4", "ext": "mp4"},
      "mpa": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
      "mpe": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
      "mpeg": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
      "mpg": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
      "mpv2": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
      "mqv": {"order": 12, "mime": "video/quicktime", "ext": "mov"},
      "oga": {"order": 11, "mime": "audio/ogg", "ext": "ogg"},
      "ogg": {"order": 11, "mime": "audio/ogg", "ext": "ogg"},
      "ogv": {"order": 2, "mime": "video/ogg", "ext": "ogv"},
      "opus": {"order": 11, "mime": "audio/ogg", "ext": "ogg"},
      "png": {"order": 15, "mime": "image/png", "ext": "png"},
      "qt": {"order": 12, "mime": "video/quicktime", "ext": "mov"},
      "spx": {"order": 11, "mime": "audio/ogg", "ext": "ogg"},
      "tif": {"order": 18, "mime": "image/tiff", "ext": "tif"},
      "tiff": {"order": 19, "mime": "image/tiff", "ext": "tif"},
      "vbk": {"order": 5, "mime": "video/mpeg", "ext": "mpeg"},
