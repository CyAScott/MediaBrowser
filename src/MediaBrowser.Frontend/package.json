{
  "name": "mediabrowser.frontend",
  "version": "1.0.0",
  "description": "This project was generated using [Angular CLI](https://github.com/angular/angular-cli) version 21.0.0.",
  "main": "index.js",
  "scripts": {
    "clean": "rm -f -r ../MediaBrowser/wwwroot",
    "build": "npm run clean && ng build && mv ../MediaBrowser/wwwroot/browser/* ../MediaBrowser/wwwroot/ && rmdir ../MediaBrowser/wwwroot/browser",
    "ng": "ng",
    "serve": "ng serve",
    "build-angular": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@playwright/test": "^1.42.0",
    "@vitest/coverage-v8": "^4.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  }
